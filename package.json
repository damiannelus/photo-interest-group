{
  "name": "photo-interest-group",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run --passWithNoTests app/",
    "test:watch": "vitest",
    "test:rules": "vitest run tests/rules",
    "test:rules:emulator": "firebase emulators:exec --only firestore \"vitest run tests/rules\""
  },
  "dependencies": {
    "@react-router/node": "7.16.0",
    "firebase": "^12.14.0",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@react-router/dev": "7.16.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.9"
  }
}
